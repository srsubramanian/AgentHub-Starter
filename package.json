{
  "name": "agui-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,agent -c blue,green \"npm run dev:web\" \"npm run dev:agent\"",
    "dev:web": "next dev",
    "dev:agent": "cd agent && uv run uvicorn agent.main:app --reload --port 8000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-json-patch": "^3.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.11.0",
    "next": "^15.3.2",
    "postcss": "^8.5.12",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "typescript": "^5.8.3"
  }
