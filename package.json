{
  "name": "agui-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,agent -c blue,green \"npm run dev:web\" \"npm run dev:agent\"",
    "dev:web": "next dev",
    "dev:agent": "cd agent && uv run uvicorn agent.main:app --reload --port 8000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "typescript": "^5.8.3"
  }
}
