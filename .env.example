# =============================================================================
# AgentHub Starter — Environment Variables
# =============================================================================
# Copy this file to .env.local (Next.js) and agent/.env (Python agent).
# All values below are required unless marked optional.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS / Bedrock
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: only needed for temporary credentials (e.g. SSO, AssumeRole)
# AWS_SESSION_TOKEN=

# Cross-region inference profile IDs — verify these exist in your account
BEDROCK_AGENT_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_CLASSIFIER_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# -----------------------------------------------------------------------------
# Tenant role mapping (starter stub — two hardcoded tenants)
# -----------------------------------------------------------------------------
TENANT_A_ROLE_ARN=arn:aws:iam::123456789012:role/agui-starter-tenant-a-role
TENANT_B_ROLE_ARN=arn:aws:iam::123456789012:role/agui-starter-tenant-b-role

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Shared between Next.js Route Handler and FastAPI agent for JWT verification
JWT_SECRET=

# -----------------------------------------------------------------------------
# Agent
# -----------------------------------------------------------------------------
AGENT_PORT=8000
AGENT_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# MCP servers (optional)
# -----------------------------------------------------------------------------
# Path to MCP server config (relative to agent/ or absolute).
# See agent/mcp_servers.json.example for the format.
# If unset or file missing, no MCP servers are loaded — agent works without them.
MCP_SERVERS_CONFIG=mcp_servers.json

# -----------------------------------------------------------------------------
# Phase 7+ only — leave blank for starter
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# PHOENIX_ENDPOINT=
# PHOENIX_API_KEY=
